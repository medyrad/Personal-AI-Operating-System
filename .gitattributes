# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicit text types
*.py     text diff=python
*.ts     text
*.tsx    text
*.js     text
*.jsx    text
*.json   text
*.md     text
*.yml    text
*.yaml   text
*.toml   text
*.cfg    text
*.ini    text
*.sh     text eol=lf
Makefile text eol=lf

# Binary types — never diff, never normalize
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
*.pdf    binary

# Lockfiles — keep out of language-stats and PR diffs by default
uv.lock              -diff linguist-generated
pnpm-lock.yaml        -diff linguist-generated
package-lock.json      -diff linguist-generated

# Vendor / generated documentation
docs/adr/*.md linguist-documentation
